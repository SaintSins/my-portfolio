---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Tools</div>
  </div>

  <HorizontalCard
    title="Static Site Generator"
    img="/Static-Site-Generator.png"
    desc="A custom, recursive Static Site Generator built in Python. This engine reads a directory tree of Markdown files, translates them into HTML, injects them into a base template, and outputs a complete, deploy-ready website."
    url="https://github.com/SaintSins/Static-Site-Generator"
    badge="NEW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="AI Coding Agent"
    img="/Coding-Agent.png"
    desc="A self-correcting, tool-enabled AI Agent framework built using Gemini that is designed to navigate files, write Python code, and debug in real-time."
    url="https://github.com/SaintSins/Agentic-Ai-Bootdev-Practice"
  />
</BaseLayout>
